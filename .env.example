# Public event info — safe to commit
NEXT_PUBLIC_EVENT_DATE="June 2026"
NEXT_PUBLIC_EVENT_DATE_LONG="Sunday · June 28, 2026"
NEXT_PUBLIC_EVENT_CITY="Location shared with confirmed guests"
NEXT_PUBLIC_EVENT_LOCATION_SHORT="Location shared with confirmed guests"
NEXT_PUBLIC_EVENT_REGION_SHORT="NYC / Long Island area"

# Mailchimp — get these at https://admin.mailchimp.com
# API key: Account → Extras → API keys. Format: xxxxxxxxxxxxxxxx-us21
# Audience ID: Audience → Settings → Audience name and defaults → "Unique id for audience"
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# Admin token — required for /api/admin/export and /api/admin/sync-tickets.
# Generate a long random string (e.g. `openssl rand -hex 32`).
# CSV export:   GET /api/admin/export?token=YOUR_TOKEN
#               &format=json for JSON, &notes=0 to skip per-member notes
# Sync tickets: POST /api/admin/sync-tickets?token=YOUR_TOKEN
ADMIN_EXPORT_TOKEN=

# Upstash Redis — atomic ticket-number counter (eliminates race conditions).
# Provision via Vercel: Project → Storage → Marketplace → Upstash Redis →
# Connect. The two env vars below are auto-injected. Locally, copy them
# from the Vercel dashboard.
#
# After connecting Upstash for the first time, run the sync once to import
# any existing Mailchimp TKT_NUMs:
#   curl -X POST "https://arrival-list.vercel.app/api/admin/sync-tickets?token=YOUR_TOKEN"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
